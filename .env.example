# Copie este arquivo para .env em desenvolvimento local ou configure as variáveis no Render.
# Nunca salve Client Secret real no GitHub.

APS_CLIENT_ID=cole_aqui_o_client_id_do_app_instrumentos
APS_CLIENT_SECRET=cole_aqui_o_client_secret_do_app_instrumentos
APS_CALLBACK_URL=http://localhost:3000/api/auth/callback
# Produção no Render:
# APS_CALLBACK_URL=https://g5-instrumentos-controle.onrender.com/api/auth/callback

# Escopos APS/ACC utilizados pela aplicação.
APS_SCOPES=data:read data:write data:create account:read

PORT=3000
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=troque_por_uma_frase_grande_e_aleatoria
SESSION_MAX_AGE_MS=1209600000
NODE_ENV=development
